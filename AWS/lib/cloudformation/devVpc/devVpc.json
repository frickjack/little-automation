{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Metadata": {
    "License": "Apache-2.0"
  },
  "Description": "IPv6 enabled VPC with a single public subnet and a standalone development EC2 instance.",
  "Parameters": {
    "WhitelistIpV4": {
      "Type": "String",
      "Description": "IPv4 CIDR for external access to specified ports (e.g., 1.2.3.4/32)",
      "AllowedPattern": "(\\d{1,3}\\.){3}\\d{1,3}/\\d{1,2}",
      "ConstraintDescription": "must be a valid IPv4 CIDR range."
    },
    "WhitelistIpV6": {
      "Type": "String",
      "Description": "IPv6 CIDR for external access to specified ports (e.g., ::/0)",
      "Default": "fd00::/8",
      "ConstraintDescription": "must be a valid IPv6 CIDR range."
    },
    "InstanceType": {
      "Type": "String",
      "Description": "EC2 instance type",
      "Default": "m6g.medium"
    },
    "AmiId": {
      "Type": "AWS::SSM::Parameter::Value<AWS::EC2::Image::Id>",
      "Default": "/aws/service/ami-amazon-linux-latest/al2023-ami-kernel-6.1-arm64",
      "Description": "The AMI ID for the instance. Defaults to the latest Amazon Linux 2023 ARM64 AMI."
    },
    "AuthorizedKeys": {
      "Type": "CommaDelimitedList",
      "Description": "Comma-separated list of public SSH keys to authorize for ec2-user",
      "Default": ""
    },
    "ReubenIamRoleName": {
      "Type": "String",
      "Description": "The name of the IAM role to associate with the instance",
      "Default": ""
    }
  },
  "Conditions": {
    "HasIamRole": { "Fn::Not": [ { "Fn::Equals": [ { "Ref": "ReubenIamRoleName" }, "" ] } ] }
  },
  "Resources": {
    "VPC": {
      "Type": "AWS::EC2::VPC",
      "Properties": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": "true",
        "EnableDnsHostnames": "true",
        "Tags": [
          { "Key": "Name", "Value": "devVpc" },
          {{ stackTagsStr }}
        ]
      }
    },
    "Ipv6CidrBlock": {
      "Type": "AWS::EC2::VPCCidrBlock",
      "Properties": {
        "AmazonProvidedIpv6CidrBlock": true,
        "VpcId": { "Ref": "VPC" }
      }
    },
    "InternetGateway": {
      "Type": "AWS::EC2::InternetGateway",
      "Properties": {
        "Tags": [
          { "Key": "Name", "Value": "devVpc-igw" },
          {{ stackTagsStr }}
        ]
      }
    },
    "VPCGatewayAttachment": {
      "Type": "AWS::EC2::VPCGatewayAttachment",
      "Properties": {
        "VpcId": { "Ref": "VPC" },
        "InternetGatewayId": { "Ref": "InternetGateway" }
      }
    },
    "PublicSubnet": {
      "Type": "AWS::EC2::Subnet",
      "DependsOn": "Ipv6CidrBlock",
      "Properties": {
        "VpcId": { "Ref": "VPC" },
        "AvailabilityZone": { "Fn::Select": [ 0, { "Fn::GetAZs": "" } ] },
        "CidrBlock": "10.0.1.0/24",
        "Ipv6CidrBlock": {
          "Fn::Select": [ 
            0, 
            { "Fn::Cidr": [ { "Fn::Select": [ 0, { "Fn::GetAtt": [ "VPC", "Ipv6CidrBlocks" ] } ] }, 1, 64 ] } 
          ]
        },
        "AssignIpv6AddressOnCreation": true,
        "MapPublicIpOnLaunch": true,
        "Tags": [
          { "Key": "Name", "Value": "devVpc-public-subnet" },
          {{ stackTagsStr }}
        ]
      }
    },
    "RouteTable": {
      "Type": "AWS::EC2::RouteTable",
      "Properties": {
        "VpcId": { "Ref": "VPC" },
        "Tags": [
          { "Key": "Name", "Value": "devVpc-public-routes" },
          {{ stackTagsStr }}
        ]
      }
    },
    "DefaultRouteIpv4": {
      "Type": "AWS::EC2::Route",
      "DependsOn": "VPCGatewayAttachment",
      "Properties": {
        "RouteTableId": { "Ref": "RouteTable" },
        "DestinationCidrBlock": "0.0.0.0/0",
        "GatewayId": { "Ref": "InternetGateway" }
      }
    },
    "DefaultRouteIpv6": {
      "Type": "AWS::EC2::Route",
      "DependsOn": "VPCGatewayAttachment",
      "Properties": {
        "RouteTableId": { "Ref": "RouteTable" },
        "DestinationIpv6CidrBlock": "::/0",
        "GatewayId": { "Ref": "InternetGateway" }
      }
    },
    "SubnetRouteTableAssociation": {
      "Type": "AWS::EC2::SubnetRouteTableAssociation",
      "Properties": {
        "SubnetId": { "Ref": "PublicSubnet" },
        "RouteTableId": { "Ref": "RouteTable" }
      }
    },
    "InstanceSecurityGroup": {
      "Type": "AWS::EC2::SecurityGroup",
      "Properties": {
        "GroupDescription": "Security group for dev instance with restricted external access and unrestricted internal access",
        "VpcId": { "Ref": "VPC" },
        "SecurityGroupIngress": [
          { "IpProtocol": "tcp", "FromPort": 22, "ToPort": 22, "CidrIp": { "Ref": "WhitelistIpV4" } },
          { "IpProtocol": "tcp", "FromPort": 8080, "ToPort": 8080, "CidrIp": { "Ref": "WhitelistIpV4" } },
          { "IpProtocol": "tcp", "FromPort": 8443, "ToPort": 8443, "CidrIp": { "Ref": "WhitelistIpV4" } },
          { "IpProtocol": "tcp", "FromPort": 9080, "ToPort": 9080, "CidrIp": { "Ref": "WhitelistIpV4" } },
          { "IpProtocol": "tcp", "FromPort": 9443, "ToPort": 9443, "CidrIp": { "Ref": "WhitelistIpV4" } },
          { "IpProtocol": "tcp", "FromPort": 10080, "ToPort": 10080, "CidrIp": { "Ref": "WhitelistIpV4" } },
          { "IpProtocol": "tcp", "FromPort": 10443, "ToPort": 10443, "CidrIp": { "Ref": "WhitelistIpV4" } },
          
          { "IpProtocol": "tcp", "FromPort": 22, "ToPort": 22, "CidrIpv6": { "Ref": "WhitelistIpV6" } },
          { "IpProtocol": "tcp", "FromPort": 8080, "ToPort": 8080, "CidrIpv6": { "Ref": "WhitelistIpV6" } },
          { "IpProtocol": "tcp", "FromPort": 8443, "ToPort": 8443, "CidrIpv6": { "Ref": "WhitelistIpV6" } },
          { "IpProtocol": "tcp", "FromPort": 9080, "ToPort": 9080, "CidrIpv6": { "Ref": "WhitelistIpV6" } },
          { "IpProtocol": "tcp", "FromPort": 9443, "ToPort": 9443, "CidrIpv6": { "Ref": "WhitelistIpV6" } },
          { "IpProtocol": "tcp", "FromPort": 10080, "ToPort": 10080, "CidrIpv6": { "Ref": "WhitelistIpV6" } },
          { "IpProtocol": "tcp", "FromPort": 10443, "ToPort": 10443, "CidrIpv6": { "Ref": "WhitelistIpV6" } },

          { "IpProtocol": "-1", "SourceSecurityGroupId": { "Fn::GetAtt": [ "InstanceSecurityGroup", "GroupId" ] }, "Description": "Allow unrestricted internal access" }
        ],
        "SecurityGroupEgress": [
          { "IpProtocol": "-1", "CidrIp": "0.0.0.0/0", "Description": "Allow all outbound IPv4" },
          { "IpProtocol": "-1", "CidrIpv6": "::/0", "Description": "Allow all outbound IPv6" }
        ],
        "Tags": [
          { "Key": "Name", "Value": "devVpc-sg" },
          {{ stackTagsStr }}
        ]
      }
    },
    "ReubenDevInstanceProfile": {
      "Type": "AWS::IAM::InstanceProfile",
      "Condition": "HasIamRole",
      "Properties": {
        "Roles": [ { "Ref": "ReubenIamRoleName" } ]
      }
    },
    "ReubenDevInstance": {
      "Type": "AWS::EC2::Instance",
      "Properties": {
        "IamInstanceProfile": { "Fn::If": [ "HasIamRole", { "Ref": "ReubenDevInstanceProfile" }, { "Ref": "AWS::NoValue" } ] },
        "InstanceType": { "Ref": "InstanceType" },
        "ImageId": { "Ref": "AmiId" },
        "SubnetId": { "Ref": "PublicSubnet" },
        "SecurityGroupIds": [ { "Ref": "InstanceSecurityGroup" } ],
        "BlockDeviceMappings": [
          {
            "DeviceName": "/dev/xvda",
            "Ebs": {
              "VolumeSize": 20,
              "Encrypted": true
            }
          },
          {
            "DeviceName": "/dev/sdb",
            "Ebs": {
              "VolumeSize": 100,
              "Encrypted": true
            }
          }
        ],
        "UserData": {
          "Fn::Base64": {
            "Fn::Sub": [
              "#cloud-config\nssh_authorized_keys:\n  - ${Keys}",
              {
                "Keys": {
                  "Fn::Join": [
                    "\n  - ",
                    { "Fn::Split": [ ",", { "Ref": "AuthorizedKeys" } ] }
                  ]
                }
              }
            ]
          }
        },
        "Tags": [
          { "Key": "Name", "Value": "devVpc-instance" },
          {{ stackTagsStr }}
        ]
      }
    }
  },
  "Outputs": {
    "VpcId": {
      "Value": { "Ref": "VPC" },
      "Description": "VPC ID"
    },
    "ReubenDevInstancePublicIp": {
      "Value": { "Fn::GetAtt": [ "ReubenDevInstance", "PublicIp" ] },
      "Description": "Public IPv4 address of the dev instance"
    },
    "ReubenDevInstancePublicIpv6": {
      "Value": { "Fn::Select": [ 0, { "Fn::GetAtt": [ "ReubenDevInstance", "Ipv6Addresses" ] } ] },
      "Description": "Public IPv6 address of the dev instance"
    }
  }
}
